{
  "name": "storeplatedemo",
  "version": "2.5.5",
  "description": "Astro and Shopify Storefront API boilerplate",
  "author": "zeon.studio",
  "license": "MIT",
  "packageManager": "npm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node scripts/themeGenerator.js --watch\" \"astro dev\"",
    "build": "node scripts/themeGenerator.js && astro build",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy",
    "cf:preview": "npm run build && wrangler dev",
    "format": "prettier -w ./src",
    "check": "astro check",
    "remove-darkmode": "node scripts/removeDarkmode.js && npm run format"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "@nanostores/react": "^1.1.0",
    "astro": "^6.4.6",
    "astro-auto-import": "^0.5.1",
    "astro-font": "^1.1.0",
    "date-fns": "^4.1.0",
    "github-slugger": "^2.0.0",
    "js-cookie": "^3.0.5",
    "marked": "^18.0.0",
    "nanostores": "^1.2.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-gravatar": "^2.6.3",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5",
    "swiper": "^12.1.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-gravatar": "^2.6.14",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-bootstrap-grid": "^7.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "esbuild": "$esbuild",
    "vite": "8.0.16",
    "yaml": "2.9.0",
    "shell-quote": "1.8.4"
  }
}
